{
  "manifest_version": 3,
  "name": "Hivey AI — IA multi-fournisseurs",
  "version": "2.174.0",
  "description": "Sidebar IA open-source type Sider : branchez votre IA (Claude, OpenAI, Gemini, Mistral, Groq, DeepSeek, xAI, Perplexity, Together, Fireworks, OpenRouter, Ollama/LM Studio local…). Liste les modèles réellement dispo selon votre clé/compte. Lit page et onglets, résume, traduit, améliore (presets), compare un modèle à un autre, artifacts interactifs, images, capture de zone, thèmes, agent (avec garde-fous). Historique local, 100% BYOK.",
  "author": "Florian Martins",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-sidebar-open-router@github",
      "strict_min_version": "121.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "contextMenus",
    "clipboardWrite",
    "identity",
    "declarativeNetRequest",
    "alarms",
    "notifications"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "frame_unblock",
        "enabled": true,
        "path": "rules/frame-unblock.json"
      }
    ]
  },
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://openrouter.ai/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.mistral.ai/*",
    "https://api.groq.com/*",
    "https://api.deepseek.com/*",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "src/background/background.js"
    ],
    "type": "module"
  },
  "sidebar_action": {
    "default_title": "Hivey AI",
    "default_panel": "src/sidebar/sidebar.html",
    "default_icon": {
      "48": "icons/icon.svg",
      "96": "icons/icon.svg"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/agent-frame.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "vendor/browser-polyfill.min.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://app.hivey.be/*",
        "https://code.hivey.be/*"
      ],
      "js": [
        "vendor/browser-polyfill.min.js",
        "src/content/hivey-bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://copilot.microsoft.com/*",
        "https://chat.mistral.ai/*",
        "https://chat.deepseek.com/*",
        "https://chat.qwen.ai/*",
        "https://www.kimi.com/*",
        "https://chat.z.ai/*",
        "https://huggingface.co/*"
      ],
      "js": [
        "src/content/webchat-bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "commands": {
    "_execute_sidebar_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      }
    }
  }
}
