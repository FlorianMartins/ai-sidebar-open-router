{
  "manifest_version": 3,
  "name": "Hivey AI — IA multi-fournisseurs",
  "version": "2.195.0",
  "description": "Sidebar IA (BYOK) : chat, lecture page/élément, traduction, résumé, images, agent. Claude, OpenAI, Gemini, OpenRouter, etc.",
  "minimum_chrome_version": "119",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "contextMenus",
    "clipboardWrite",
    "identity",
    "sidePanel",
    "declarativeNetRequest",
    "alarms",
    "notifications"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "frame_unblock",
        "enabled": true,
        "path": "rules/frame-unblock.json"
      }
    ]
  },
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://openrouter.ai/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.mistral.ai/*",
    "https://api.groq.com/*",
    "https://api.deepseek.com/*",
    "<all_urls>"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Hivey AI",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidebar/sidebar.html"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/agent-frame.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "vendor/browser-polyfill.min.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://app.hivey.be/*",
        "https://code.hivey.be/*"
      ],
      "js": [
        "vendor/browser-polyfill.min.js",
        "src/content/hivey-bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://copilot.microsoft.com/*",
        "https://chat.mistral.ai/*",
        "https://chat.deepseek.com/*",
        "https://chat.qwen.ai/*",
        "https://www.kimi.com/*",
        "https://chat.z.ai/*",
        "https://huggingface.co/*"
      ],
      "js": [
        "src/content/webchat-bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
